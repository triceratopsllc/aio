{
  "name": "@triceratops/aio",
  "version": "0.1.0",
  "description": "AI Overview / SEO optimization toolkit — JSON-LD builders, sitemap, robots.txt, OGP meta, for Vite/Next.js/WordPress sites",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./core": {
      "types": "./dist/src/core/index.d.ts",
      "default": "./dist/src/core/index.js"
    },
    "./react-helmet": {
      "types": "./dist/src/react-helmet/index.d.ts",
      "default": "./dist/src/react-helmet/index.js"
    },
    "./next": {
      "types": "./dist/src/next/index.d.ts",
      "default": "./dist/src/next/index.js"
    },
    "./audit": {
      "types": "./dist/src/audit/index.d.ts",
      "default": "./dist/src/audit/index.js"
    },
    "./templates/robots.txt": "./templates/robots.txt"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "audit": "tsx bin/audit.ts",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "aio-audit": "./bin/audit.ts"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "react-helmet-async": ">=2"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true },
    "react": { "optional": true },
    "react-helmet-async": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "next": "^15.0.0",
    "react": "^18.3.0",
    "react-helmet-async": "^2.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
